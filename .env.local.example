# Admin-PIN für /admin und GET /api/orders
ADMIN_PIN=rajmahal2024

# ─── E-Mail (SMTP) ───────────────────────────────────────────────────────────
# Beispiel 1: Gmail (App-Passwort unter https://myaccount.google.com/apppasswords)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=ihre-adresse@gmail.com
# SMTP_PASS=xxxx xxxx xxxx xxxx   # 16-stelliges App-Passwort
# MAIL_TO=bestellungen@rajmahal-schkeuditz.de
# MAIL_FROM=ihre-adresse@gmail.com

# Beispiel 2: Strato / Ionos
# SMTP_HOST=smtp.strato.de
# SMTP_PORT=465
# SMTP_SECURE=true
# SMTP_USER=bestellungen@rajmahal-schkeuditz.de
# SMTP_PASS=IhrPasswort
# MAIL_TO=bestellungen@rajmahal-schkeuditz.de
# MAIL_FROM=bestellungen@rajmahal-schkeuditz.de

# ─── PayPal ──────────────────────────────────────────────────────────────────
# Echte Client-ID aus https://developer.paypal.com/dashboard/
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=AxxxYourLiveClientIDxxx
